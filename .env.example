# Environment variables for Techadyant Labs

# Cloudflare Worker URL for the DeepSeek API proxy.
# Deploy the worker (workers/deepseek-proxy/) first, then paste its URL here.
# The URL is safe to expose in the client bundle — your API key lives in the Worker.
NEXT_PUBLIC_DEEPSEEK_WORKER_URL=

# n8n webhook for the Pain Point Radar widget
NEXT_PUBLIC_N8N_WEBHOOK_URL=
